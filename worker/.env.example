# Path to SQLite file — relative to worker/ directory, or absolute
SQLITE_PATH=../web/prisma/dev.db

# Upload directory — must match web's UPLOAD_DIR resolved path
UPLOAD_BASE_DIR=../local_uploads

# Seconds to wait between DB polls when queue is empty
POLL_INTERVAL=1.0

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
