{
  "name": "ttb-label-review-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.dev -- next dev",
    "dev:hybrid": "dotenv -e .env.hybrid -- next dev",
    "worker:dev": "node scripts/start-worker.mjs",
    "worker:hybrid": "node scripts/start-worker.mjs --env hybrid",
    "start:all": "concurrently -n \"web,worker\" -c \"blue,yellow\" --kill-others \"npm run dev\" \"npm run worker:dev\"",
    "start:hybrid": "concurrently -n \"web,worker\" -c \"blue,yellow\" --kill-others \"npm run dev:hybrid\" \"npm run worker:hybrid\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "dotenv -e .env.dev -- prisma migrate dev",
    "db:migrate:hybrid": "dotenv -e .env.hybrid -- prisma migrate deploy",
    "db:push:hybrid": "dotenv -e .env.hybrid -- prisma db push --schema prisma/schema.postgresql.prisma",
    "db:generate": "prisma generate",
    "db:studio": "dotenv -e .env.dev -- prisma studio",
    "db:studio:hybrid": "dotenv -e .env.hybrid -- prisma studio",
    "db:reset": "dotenv -e .env.dev -- prisma migrate reset --force",
    "cleanup": "node ../scripts/cleanup.mjs"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@prisma/client": "^5.22.0",
    "csv-stringify": "^6.5.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
