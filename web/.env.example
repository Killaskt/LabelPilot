# Database — Prisma SQLite (local dev)
# Swap to postgresql://... for production
DATABASE_URL="file:./dev.db"

# File storage — local filesystem
# Set to an absolute path or a path relative to web/
# Swap to Azure Blob connection string in production
UPLOAD_DIR="../local_uploads"

# Per-file size limit in megabytes
MAX_FILE_SIZE_MB=10

# Maximum number of files per job
MAX_FILES=10

# Rate limiting (in-memory for local dev — use Redis in production)
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_MS=60000

# Auth — shared-secret invite code
# INVITE_CODE=invite-code-here
